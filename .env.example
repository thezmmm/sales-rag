# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose 'ollama' (local) or 'openai' (OpenAI API / any compatible endpoint)
LLM_PROVIDER=ollama

# ── Ollama settings (used when LLM_PROVIDER=ollama) ──────────────────────────
OLLAMA_MODEL=llama3.2:3b
# OLLAMA_HOST=http://localhost:11434   # uncomment to override the default

# ── OpenAI-compatible settings (used when LLM_PROVIDER=openai) ───────────────
OPENAI_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1   # Groq example

# ── Vector database ───────────────────────────────────────────────────────────
CHROMA_DB_PATH=./src/vector_db/chroma_db

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Dataset ───────────────────────────────────────────────────────────────────
DATA_PATH=./data/superstore.csv
